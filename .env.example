# Database Configuration
# For local development: Use your local PostgreSQL connection string
# For production: Use Supabase connection pooling URL
# Obtain from: Supabase Dashboard > Project Settings > Database > Connection Pooling
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true"

# Direct Database Connection
# Used for Prisma migrations (bypasses connection pooling)
# Obtain from: Supabase Dashboard > Project Settings > Database > Connection String (Direct)
DIRECT_URL="postgresql://user:password@host:port/database"

# Clerk Authentication - Publishable Key
# This key is safe to expose in client-side code (NEXT_PUBLIC_ prefix)
# Obtain from: Clerk Dashboard > API Keys > Publishable Key
# Use test keys (pk_test_...) for development, live keys (pk_live_...) for production
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Clerk Authentication - Secret Key
# CRITICAL: Keep this secret! Never expose in client-side code
# Obtain from: Clerk Dashboard > API Keys > Secret Key
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production
CLERK_SECRET_KEY="sk_test_..."

# Clerk Sign-In URL
# The route where users are redirected for authentication
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# Cloudinary Configuration - Cloud Name
# Used for image upload and management
# Obtain from: Cloudinary Dashboard > Account Details > Cloud Name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"

# Cloudinary Configuration - API Key
# Used for authenticated Cloudinary operations
# Obtain from: Cloudinary Dashboard > Account Details > API Key
NEXT_PUBLIC_CLOUDINARY_API_KEY="your_api_key"
